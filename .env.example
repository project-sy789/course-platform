# Backend
DB_PASSWORD=change-me-strong
DATABASE_URL=postgresql+psycopg://course:change-me-strong@db:5432/course
REDIS_URL=redis://redis:6379/0

# openssl rand -hex 64
JWT_SECRET=replace-with-64-byte-hex
JWT_ALG=HS256
JWT_TTL_MIN=10080
PB_SESSION_TTL_SEC=300

# openssl rand -base64 32  (must decode to exactly 32 bytes)
KEK_BASE64=replace-with-base64-32-bytes
# Production preferred: leave KEK_BASE64 empty and point KEK_FILE at a path
# loaded via systemd LoadCredential= or a Docker secret. With KEK_FILE set,
# the key never appears in `env` / `docker inspect`. File may hold raw 32
# bytes OR a base64 string.
KEK_FILE=

# Public CDN base in front of R2 bucket
R2_PUBLIC_BASE=https://media.example.com

# R2 admin credentials (only used by /api/v1/admin/upload-video)
# Create a scoped API token in Cloudflare dashboard with Object R/W on the bucket.
R2_ACCOUNT_ID=
R2_BUCKET=course-videos
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Comma-separated origins allowed to call the API
CORS_ORIGINS=https://app.example.com,http://localhost:3000

# Grafana admin password
GRAFANA_PASSWORD=change-me

# Grafana alerting webhook (Discord, Slack, generic). Leave empty to disable.
ALERT_WEBHOOK_URL=

# AWS backup target (S3 Glacier Deep Archive). Used by scripts.backup_to_glacier.
# Create a separate IAM user with PutObject permission on the bucket only.
AWS_REGION=ap-southeast-1
AWS_BACKUP_BUCKET=course-platform-cold-backup
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Storage class: DEEP_ARCHIVE (~$0.001/GB, 12-48h restore) or GLACIER (~$0.004/GB, 3-5h)
AWS_BACKUP_STORAGE_CLASS=DEEP_ARCHIVE

# SMTP — defaults to the in-stack Postfix container. Switch to a managed
# provider (Resend, Postmark, SES) by changing SMTP_HOST/PORT/USER/PASSWORD —
# no code change required. Leave SMTP_HOST empty to disable email entirely
# (verification + password reset become no-ops; useful for local dev).
SMTP_HOST=mailserver
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
SMTP_USE_TLS=false

# Postfix container config (only used when SMTP_HOST=mailserver)
# MAIL_DOMAIN must be a domain you control + own SPF/DKIM/DMARC for.
# MAIL_HOSTNAME must match the VPS PTR record so mail isn't junked.
MAIL_DOMAIN=example.com
MAIL_HOSTNAME=mail.example.com
# Optional smarthost. Leave empty for direct delivery (port 25).
# Most cloud providers block outbound 25 — set this to relay through SES/SendGrid:
#   MAIL_RELAYHOST=[email-smtp.ap-southeast-1.amazonaws.com]:587
MAIL_RELAYHOST=
MAIL_RELAY_USER=
MAIL_RELAY_PASSWORD=

# Public URL of the frontend — used in verification + reset email links
FRONTEND_URL=http://localhost:3000

# Currency printed on tax invoices. The "STRIPE_" prefix is a holdover —
# Stripe itself has been removed; payments come via slip upload now.
STRIPE_CURRENCY=thb

# Thai VAT (ภาษีมูลค่าเพิ่ม). Course prices in price_cents are VAT-inclusive.
VAT_RATE_PERCENT=7

# Issuer info printed on every tax invoice (ใบกำกับภาษี).
COMPANY_NAME=
COMPANY_TAX_ID=
COMPANY_ADDRESS=
COMPANY_BRANCH=สำนักงานใหญ่
COMPANY_PHONE=
# Path inside the API container to a Thai TTF (Sarabun, Noto Sans Thai).
# Mount via docker-compose volume; leave empty to fall back to Helvetica
# (Thai glyphs render as boxes — fine for staging only).
INVOICE_FONT_PATH=
INVOICE_NUMBER_PREFIX=INV2026

# ---------- Slip-upload payment (Thai bank transfer) ----------
# Receiver bank info shown to the buyer on the checkout page.
RECEIVER_BANK_NAME=ธนาคารกสิกรไทย
RECEIVER_BANK_ACCOUNT=
RECEIVER_NAME=
# Optional. When set, the checkout page can render a PromptPay QR.
PROMPTPAY_ID=

# SlipOK auto-verify (https://slipok.com). Leave SLIPOK_API_KEY empty to
# disable auto-verify — every slip then waits for admin approval.
SLIPOK_API_KEY=
SLIPOK_BRANCH_ID=
# Satang tolerance when matching slip amount vs course price (banks sometimes
# round). 0 = exact match required.
SLIPOK_AMOUNT_TOLERANCE_SATANG=0

# E2E test bypass. Set ONLY in dev/CI. Production must leave this empty.
E2E_BYPASS_TOKEN=
