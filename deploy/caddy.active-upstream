reverse_proxy api-blue:8000 {
	header_up X-Real-IP {remote_host}
	header_up X-Forwarded-For {remote_host}
	header_up X-Forwarded-Proto {scheme}
	transport http {
		dial_timeout 2s
		response_header_timeout 30s
	}
	health_uri /healthz/ready
	health_interval 5s
	health_timeout 2s
	lb_try_duration 5s
}
