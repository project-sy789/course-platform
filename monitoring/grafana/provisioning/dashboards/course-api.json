{
  "title": "Course Platform — API",
  "uid": "course-api",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Request rate (req/s)",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum by (handler) (rate(http_requests_total{job=\"course-api\"}[5m]))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 latency (seconds)",
      "id": 2,
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, handler) (rate(http_request_duration_seconds_bucket{job=\"course-api\"}[5m])))",
          "legendFormat": "p95 {{handler}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "5xx rate",
      "id": 3,
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"course-api\",status=~\"5..\"}[5m]))"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Key endpoint denials (rate)",
      "description": "403 on /api/v1/videos/{video_id}/key — credential stuffing or replay signal",
      "id": 4,
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"course-api\",handler=~\".*get_video_key.*\",status=\"403\"}[5m]))"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "timeseries",
      "title": "Status code mix",
      "id": 5,
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_requests_total{job=\"course-api\"}[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    }
  ]
}
